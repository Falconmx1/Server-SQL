{
  "name": "server-sql",
  "version": "1.0.0",
  "description": "Servidor web ligero con interfaz para ejecutar consultas SQL en múltiples bases de datos (SQLite, MySQL, PostgreSQL)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test jest --runInBand",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:verbose": "NODE_ENV=test jest --verbose --runInBand",
    "docs": "node docs/generate.js",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "sql",
    "database",
    "web-tool",
    "sql-editor",
    "express",
    "nodejs",
    "sqlite",
    "mysql",
    "postgresql",
    "self-hosted",
    "api",
    "testing"
  ],
  "author": "Falconmx1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Falconmx1/Server-SQL.git"
  },
  "bugs": {
    "url": "https://github.com/Falconmx1/Server-SQL/issues"
  },
  "homepage": "https://github.com/Falconmx1/Server-SQL#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "mysql2": "^3.6.0",
    "pg": "^8.11.0",
    "dotenv": "^16.0.3",
    "express-session": "^1.17.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.0",
    "supertest": "^6.3.3",
    "cross-env": "^7.0.3"
  }
}
